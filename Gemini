<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FINANCE.IO // 2026 PRO FIX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Unbounded:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* Стили из твоего промпта: темная тема, шрифты и Bento-сетка */
        :root {
            --bg: #0a0a0f; --card: #16161f; --border: #1e1e2e;
            --accent: #ff6b35; --green: #00d68f; --red: #ff4757;
            --text: #e0e0e6; --muted: #808090;
            --font-main: 'Space Mono', monospace; --font-title: 'Unbounded', cursive;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; }
        body { background: var(--bg); color: var(--text); font-family: var(--font-main); padding: 20px; line-height: 1.5; }
        .container { max-width: 1100px; margin: 0 auto; }
        header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 20px; margin-bottom: 30px; }
        .btn { background: var(--card); border: 1px solid var(--border); color: var(--text); padding: 10px 20px; border-radius: 12px; cursor: pointer; font-size: 12px; transition: 0.3s; }
        .btn:hover { border-color: var(--accent); }
        .btn-primary { background: var(--accent); color: #000; font-weight: bold; border: none; }
        
        /* Modal Styles */
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); display: none; align-items: flex-end; justify-content: center; z-index: 1000; }
        .modal.active { display: flex; }
        .modal-content { background: var(--card); width: 100%; max-width: 500px; padding: 30px; border-radius: 32px 32px 0 0; border: 1px solid var(--border); transform: translateY(100%); transition: 0.4s cubic-bezier(0.19, 1, 0.22, 1); }
        .modal.active .modal-content { transform: translateY(0); }
        
        .tab-nav { display: flex; gap: 10px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
        .tab-link { cursor: pointer; color: var(--muted); font-size: 12px; text-transform: uppercase; }
        .tab-link.active { color: var(--accent); font-weight: bold; }
        
        .drop-zone { border: 2px dashed var(--border); border-radius: 16px; padding: 40px; text-align: center; cursor: pointer; transition: 0.3s; }
        .drop-zone:hover { border-color: var(--accent); background: rgba(255,107,53,0.05); }
        input[type="checkbox"] { margin-right: 8px; vertical-align: middle; }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div style="font-family: var(--font-title); font-size: 20px;">FINANCE<span>.</span>IO</div>
        <div style="display: flex; gap: 12px;">
            <button class="btn" onclick="exportData()">↑ JSON</button>
            <button class="btn btn-primary" onclick="openModal('importModal')">↓ Импорт</button>
        </div>
    </header>

    <div id="main-content">
        <h2 style="font-family: var(--font-title); opacity: 0.5;">Дашборд готов к работе</h2>
    </div>
</div>

<div id="importModal" class="modal" onclick="closeModal(event)">
    <div class="modal-content" onclick="event.stopPropagation()">
        <h3 style="font-family: var(--font-title); font-size: 14px; margin-bottom: 20px;">Импорт данных</h3>
        
        <div class="tab-nav">
            <span class="tab-link active" onclick="switchTab(this, 'json-tab')">JSON</span>
            <span class="tab-link" onclick="switchTab(this, 'csv-tab')">Swedbank CSV</span>
        </div>

        <div id="json-tab" class="tab-content">
            <div class="drop-zone" onclick="document.getElementById('file-json').click()">
                Нажмите или перетащите JSON файл
            </div>
            <input type="file" id="file-json" hidden accept=".json" onchange="processFile(this, 'json')">
        </div>

        <div id="csv-tab" class="tab-content" style="display: none;">
            <p style="font-size: 11px; color: var(--muted); margin-bottom: 15px;">Инструкция: в Swedbank выберите «Выписка» -> CSV -> Сохранить.</p>
            <div class="drop-zone" onclick="document.getElementById('file-csv').click()">
                Перетащите CSV выписку сюда
            </div>
            <input type="file" id="file-csv" hidden accept=".csv" onchange="processFile(this, 'csv')">
        </div>

        <div style="margin-top: 20px;">
            <label style="font-size: 12px;">
                <input type="checkbox" id="merge-data" checked> Добавить к существующим
            </label>
        </div>
    </div>
</div>

<script>
    let state = { transactions: [], categories: {}, nextId: 1 };
    const DB_KEY = 'FINANCE_IO_2026_DATA';

    // --- Core Logic ---
    function openModal(id) { document.getElementById(id).classList.add('active'); }
    function closeModal(e) { 
        if(e === 'force' || e.target.classList.contains('modal')) 
            document.querySelectorAll('.modal').forEach(m => m.classList.remove('active')); 
    }

    function switchTab(el, tabId) {
        document.querySelectorAll('.tab-link').forEach(l => l.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
        el.classList.add('active');
        document.getElementById(tabId).style.display = 'block';
    }

    // --- File Processing ---
    async function processFile(input, type) {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = async (e) => {
            const content = e.target.result;
            const isMerge = document.getElementById('merge-data').checked;

            if (type === 'json') {
                const data = JSON.parse(content);
                if (isMerge) {
                    state.transactions = [...state.transactions, ...(data.transactions || [])];
                    state.categories = { ...state.categories, ...(data.categories || {}) };
                } else {
                    state = data;
                }
            } else if (type === 'csv') {
                const newTxs = parseSwedbankCSV(content);
                if (isMerge) {
                    // Пропуск дубликатов по ключу дата|сумма|название
                    const existingKeys = new Set(state.transactions.map(t => `${t.date}|${t.amount}|${t.name}`));
                    const filtered = newTxs.filter(t => !existingKeys.has(`${t.date}|${t.amount}|${t.name}`));
                    state.transactions = [...state.transactions, ...filtered];
                } else {
                    state.transactions = newTxs;
                }
            }

            await saveToStorage();
            location.reload(); // Перезагрузка для обновления всех графиков
        };
        reader.readAsText(file);
    }

    // --- Parser Swedbank CSV ---
    function parseSwedbankCSV(text) {
        const lines = text.split('\n');
        const transactions = [];
        // Определение разделителя
        const delimiter = lines[0].includes(';') ? ';' : ',';

        for (let i = 1; i < lines.length; i++) {
            const cols = lines[i].split(delimiter).map(c => c.replace(/"/g, '').trim());
            if (cols.length < 5) continue;

            const date = cols[2]; // Дата операции
            const name = cols[3]; // Получатель/Отправитель
            const amount = parseFloat(cols[5].replace(',', '.')); // Сумма
            const type = amount > 0 ? 'income' : 'expense';

            if (date && !isNaN(amount)) {
                transactions.push({
                    id: Date.now() + i,
                    date: formatDate(date),
                    name: name,
                    amount: amount,
                    type: type,
                    cat: 'Прочее', // Автокатегоризация вызывается отдельно при рендере
                    pending: false
                });
            }
        }
        return transactions;
    }

    function formatDate(rawDate) {
        // Поддержка dd.mm.yyyy и yyyy-mm-dd
        if (rawDate.includes('.')) {
            const parts = rawDate.split('.');
            return `${parts[2]}-${parts[1]}-${parts[0]}`;
        }
        return rawDate;
    }

    async function saveToStorage() {
        if (window.storage) {
            await window.storage.set(DB_KEY, JSON.stringify(state));
        } else {
            localStorage.setItem(DB_KEY, JSON.stringify(state));
        }
    }

    window.exportData = () => {
        const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = `finance-io-${new Date().toISOString().split('T')[0]}.json`;
        a.click();
    }
</script>
</body>
</html>
